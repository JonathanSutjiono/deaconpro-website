# Public Sanity project configuration. These values are safe to expose to the browser.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# Required only for the manual `npm run seed:sanity` command. Never commit a real token.
SANITY_API_WRITE_TOKEN=
